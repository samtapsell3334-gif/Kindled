# Database
DATABASE_URL="postgresql://user:password@localhost:5432/kindled"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Stripe (server-side only — never expose secret key to client)
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# Stripe (client-safe)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# Creator sign-up emails (server-side only)
RESEND_API_KEY=""
CREATOR_SIGNUP_EMAIL="sam.tapsell@kindledgift.co.uk"

# AI Video (server-side only)
KLING_API_KEY=""
REVEAL_PROVIDER="kling"   # or "runway"
RUNWAY_API_KEY=""

# Media storage — Kindle Memories / sandbox videos (Vercel Blob)
BLOB_READ_WRITE_TOKEN=""          # server-side only; auto-injected on Vercel
NEXT_PUBLIC_BLOB_ENABLED=""       # "1" routes uploads to Blob (else local object URL)

# Investor gate (server-side only)
INVESTOR_PIN=""                   # 4-digit PIN; dev fallback exists — set in production

# Sandbox (v4.1) — simulated-money demo environment
NEXT_PUBLIC_DEMO_MODE="1"         # shows the demo banner + demo affordances
SANDBOX_ADMIN_SECRET=""           # gates /api/sandbox/admin + dashboard (dev fallback: kindled-admin)
SANDBOX_COMMISSION_PCT="5"        # simulated gift-card commission % (TODO-FOUNDER: real rates)
